local function makeSoulList(baseName, tiers)
    local list = {}
    table.insert(list, baseName)
    local romanMap = { "I", "II", "III", "IV", "V" }
    for i = 1, (tiers or 5) do
        table.insert(list, baseName .. " [" .. romanMap[i] .. "]")
    end
    return list
end

