local function parseAmount(str)
    if not str or str == "?" or str == "N/A" then return nil end
    str = tostring(str):gsub(",", "")
    local k = str:match("^([%d%.]+)[Kk]$")
    if k then return math.floor(tonumber(k) * 1000) end
    return tonumber(str)
end

local function waitAndGetItemAmount(itemName)
    if itemName == "Gem" then
        local ok, numObj = pcall(function()
            return LocalPlayer.PlayerGui.HUD.MenuFrame.LeftSide.Frame.Gems.Numbers
        end)
        if not ok then return "?" end
        local changed = false
        local conn = numObj:GetPropertyChangedSignal("Text"):Connect(function() changed = true end)
        local timeout = tick() + 3
        while not changed and tick() < timeout do task.wait(0.1) end
        conn:Disconnect()
        return numObj.Text
    elseif itemName == "Gold" then
        local ok, numObj = pcall(function()
            return LocalPlayer.PlayerGui.HUD.MenuFrame.LeftSide.Frame.Gold.Numbers
        end)
        if not ok then return "?" end
        local changed = false
        local conn = numObj:GetPropertyChangedSignal("Text"):Connect(function() changed = true end)
        local timeout = tick() + 3
        while not changed and tick() < timeout do task.wait(0.1) end
        conn:Disconnect()
        return numObj.Text
    elseif itemName == "Egg" then
        local ok, numObj = pcall(function()
            return LocalPlayer.PlayerGui.HUD.MenuFrame.LeftSide.Frame.Egg.Numbers
        end)
        if not ok then return "?" end
        local changed = false
        local conn = numObj:GetPropertyChangedSignal("Text"):Connect(function() changed = true end)
        local timeout = tick() + 3
        while not changed and tick() < timeout do task.wait(0.1) end
        conn:Disconnect()
        return numObj.Text
    elseif itemName == "Anniversary Coin" then
        local ok, numObj = pcall(function()
            return LocalPlayer.PlayerGui.HUD.MenuFrame.LeftSide.Frame["Anniversary Coin"].Numbers
        end)
        if not ok then return "?" end
        local changed = false
        local conn = numObj:GetPropertyChangedSignal("Text"):Connect(function() changed = true end)
        local timeout = tick() + 3
        while not changed and tick() < timeout do task.wait(0.1) end
        conn:Disconnect()
        return numObj.Text
    elseif itemName == "Exp" then
        return getItemCurrentAmount("Exp")
    elseif dataFolderItems[itemName] then
        local realName = itemName == "Sol Tokens" and "Sol Token" or itemName
        local ok, dataObj = pcall(function()
            return PlayerDataFolder:WaitForChild(realName, 3)
        end)
        if not ok or not dataObj then return "0" end
        local changed = false
        local conn = dataObj:GetPropertyChangedSignal("Value"):Connect(function() changed = true end)
        local timeout = tick() + 3
        while not changed and tick() < timeout do task.wait(0.1) end
        conn:Disconnect()
        return tostring(dataObj.Value)
    end
    local realName = resolveItemFolderName(itemName)
    local ok, folder = pcall(function()
        return PlayerItemsFolder:WaitForChild(realName, 3)
    end)
    if not ok or not folder then return "0" end
    local amountObj = folder:FindFirstChild("Amount")
    if not amountObj then return "0" end
    local changed = false
    local conn = amountObj:GetPropertyChangedSignal("Value"):Connect(function() changed = true end)
    local timeout = tick() + 3
    while not changed and tick() < timeout do task.wait(0.1) end
    conn:Disconnect()
    return tostring(amountObj.Value)
end

