        if not Options.AutoEndMatch.Value then
            inGameSince   = nil
            matchEndFired = false
            waitingReward = false
            continue
        end
        local minutes = tonumber(Options.EndMatchMinutes and Options.EndMatchMinutes.Value) or 0
        if minutes <= 0 then continue end

        if waitingReward then
            local rewardVisible = false
            pcall(function()
                rewardVisible = LocalPlayer.PlayerGui.RewardsUI.Main.Visible
            end)
            if rewardVisible then
                inGameSince   = nil
                matchEndFired = false
                waitingReward = false
                print("[AutoEndMatch] ✅ RewardsUI.Main visible → reset - waiting for next round")
            end
            continue
        end

        local gameInfoVisible = false
        pcall(function()
            gameInfoVisible = LocalPlayer.PlayerGui.HUD.InGame.Main.TOP.Visible
        end)

        if gameInfoVisible then
            if not inGameSince then
                inGameSince   = tick()
                matchEndFired = false
                print("[AutoEndMatch] ▶ Timer started " .. minutes .. " min")
            end
            local elapsed = tick() - inGameSince
            if elapsed >= minutes * 60 and not matchEndFired then
                matchEndFired = true
                waitingReward = true
                EndMatchEvent = EndMatchEvent or getEndMatchEvent()
                if EndMatchEvent then pcall(function() EndMatchEvent:FireServer() end) end
                print("[AutoEndMatch] 🔚 Fire EndMatch after " .. minutes .. " min — waiting RewardsUI.Main")
            end
        else
            if inGameSince and not matchEndFired then
                print("[AutoEndMatch] Reset — GameInfo hidden")
