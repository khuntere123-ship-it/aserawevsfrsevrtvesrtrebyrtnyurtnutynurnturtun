local function getFullChapterName(world, chapterNum, stage)
    if type(chapterNum) ~= "number" then return tostring(chapterNum) end
    if stage == "Raids" then
        local prefix = StageData.Raids.chapterPrefix[world]
        return prefix and (prefix .. chapterNum) or (world .. "_Chapter" .. chapterNum)
    end
    if stage == "Ranger" then return world .. "_RangerStage" .. chapterNum end
    return world .. "_Chapter" .. chapterNum
end

