                    local wdata = stageData.worldMap[SelectedEventWorld]
                        or stageData.worldMap[stageData.worlds[1]]

                    PlayRoomEvent:FireServer("Create")
                    task.wait(0.5)

                    if SelectedEventStage == "Ghoul Hunt" then
                        PlayRoomEvent:FireServer("Fate Mode")
                        task.wait(0.3)
                    elseif SelectedEventStage == "Boss Attack" then
                        PlayRoomEvent:FireServer("Boss-Attack-2.5")
                        task.wait(0.3)
                    else
                        local chapterKey  = wdata.chapterKey or wdata.key
                        local chapterName = chapterKey .. "_Act" .. tostring(SelectedEventChapter)
                        PlayRoomEvent:FireServer("Change-Mode",    { Mode    = wdata.mode }) ; task.wait(0.3)
                        PlayRoomEvent:FireServer("Change-World",   { World   = wdata.key  }) ; task.wait(0.3)
                        PlayRoomEvent:FireServer("Change-Chapter", { Chapter = chapterName }) ; task.wait(0.3)
                    end

                    local ok = pcall(function()
                        PlayRoomEvent:FireServer("Submit")
                    end)
                    if ok then
                        task.wait(Options.EventStartDelay.Value)
                        PlayRoomEvent:FireServer("Start")
                        task.wait(10)
                    else
                        print("[Event] ❌ Submit failed - retrying in 5s")
                        task.wait(5)
                    end
                end
                task.wait(2)
            end
        end)
    end
end)

