local function doRequest(payload)
    if DiscordConfig.webhookURL == "" or not DiscordConfig.enabled then
        print("❌ Webhook disabled or URL empty")
        return
    end
    task.spawn(function()
        local success = false
        local errorMsg = ""
        do
            local ok, err = pcall(function()
                HttpService:PostAsync(
                    DiscordConfig.webhookURL,
                    payload,
                    Enum.HttpContentType.ApplicationJson
                )
            end)
            if ok then success = true print("✅ Webhook sent via HttpService!")
            else errorMsg = tostring(err) end
        end
        if not success and request then
            local ok, err = pcall(function()
                request({
                    Url = DiscordConfig.webhookURL,
                    Method = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body = payload,
                })
            end)
            if ok then success = true print("✅ Webhook sent via request!")
            else errorMsg = tostring(err) end
        end
        if not success and syn and syn.request then
            local ok, err = pcall(function()
                syn.request({
                    Url = DiscordConfig.webhookURL,
                    Method = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body = payload,
                })
            end)
            if ok then success = true print("✅ Webhook sent via syn.request!")
            else errorMsg = tostring(err) end
        end
        if not success then
            print("❌ Webhook failed - " .. (errorMsg ~= "" and errorMsg or "All methods failed"))
        end
    end)
end

local function sendRoundEnd(rewardItems, elapsed)
    local pingStr = (DiscordConfig.pingOnItem and DiscordConfig.userID ~= "") and ("<@" .. DiscordConfig.userID .. ">") or ""
    local name    = LocalPlayer.Name
    local okMode, gameMode = pcall(function()
        return LocalPlayer.PlayerGui.HUD.InGame.Main.GameInfo.Gamemode.Label.Text
    end)
    local okStage, stageLabel = pcall(function()
        return LocalPlayer.PlayerGui.HUD.InGame.Main.GameInfo.Stage.Label.Text
    end)
    local stageInfo = (okMode and gameMode or SelectedStage) .. " • " .. (okStage and stageLabel or SelectedWorldDisplay .. " • " .. SelectedChapterDisplay)
    local rewardsText = "🎁 **Rewards**\n"
    local results = {}
    local pending = 0
    for _, item in ipairs(rewardItems) do
        if item.name ~= "Exp" then
            pending = pending + 1
            task.spawn(function()
                results[item.name] = waitAndGetItemAmount(item.name)
                pending = pending - 1
            end)
        end
    end
    while pending > 0 do task.wait(0.05) end
    for _, item in ipairs(rewardItems) do
        local displayName = item.name == "Exp" and "LV" or item.name
        local icon = icons[item.name]
        local prefix = icon and (icon .. " ") or "• "
        if item.name == "Exp" then
            local ok, lvText = pcall(function()
                return LocalPlayer.PlayerGui.HUD.ExpBar.Numbers.Text
            end)
            local lvNum = "?"
            if ok and lvText then
                lvNum = lvText:match("Level%s*(%d+)") or lvText:match("Lv%s*(%d+)") or "?"
            end
            rewardsText = rewardsText .. "⭐ **" .. displayName .. "** " .. lvNum .. "\n"
        else
            local current = results[item.name] or "?"
            rewardsText = rewardsText .. prefix .. "**" .. displayName .. "** +" .. tostring(item.amount) .. " → " .. current .. "\n"
        end
    end
    local description =
        "✨ **In-Game Name:** ||" .. name .. "||\n\n" ..
        stageInfo .. "\n\n" ..
        "```\nResult: + WON  Time: " .. elapsed .. "\n```\n" ..
        rewardsText
    local payload = HttpService:JSONEncode({
        content    = pingStr,
        username   = "HamYai69Hub",
        avatar_url = "https://i.postimg.cc/rwbBMph6/preview-Picsart-Ai-Image-Enhancer.png",
        embeds = {
            {
                title       = "⚔️ [🎊 1 YR] Re:Rangers X — Stage Ended",
                description = description,
                color       = 0x7B2FBE,
                image       = { url = "https://c.tenor.com/zWjGMaQ8h5EAAAAd/tenor.gif" },
                footer      = { text = "HamYai69Hub • Made by MitchAK • " .. os.date("%d/%m/%Y %H:%M") },
            },
