local function buyItemDirect(itemName)
    local beforeStr = getItemAmount(itemName)
    local beforeNum = parseAmount(beforeStr) or 0

    pcall(function()
        MerchantEvent:FireServer(itemName, 9999)
    end)

    local deadline = tick() + 3
    local afterNum = beforeNum
    while tick() < deadline do
        task.wait(0.2)
        local cur = parseAmount(getItemAmount(itemName)) or 0
        if cur > beforeNum then
            afterNum = cur
            break
        end
    end

    local bought = afterNum > beforeNum

    if bought then
        task.wait(0.2)
        pcall(function()
            local vp = workspace.CurrentCamera.ViewportSize
            local vim = game:GetService("VirtualInputManager")
            vim:SendMouseButtonEvent(vp.X * 0.85, vp.Y * 0.85, 0, true, game, 0)
            task.wait(0.1)
            vim:SendMouseButtonEvent(vp.X * 0.85, vp.Y * 0.85, 0, false, game, 0)
        end)
    end
    return bought, tostring(afterNum)
end

